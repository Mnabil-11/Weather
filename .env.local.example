# Copy this file to .env.local and fill in real values. Never commit .env.local.

# Required — weather data.
# 1. Sign up (free) at https://www.weatherapi.com/signup.aspx
# 2. Copy your key from https://www.weatherapi.com/my/
# 3. New keys can take up to ~30 minutes to activate.
WEATHER_API_KEY=replace_with_your_key

# Optional — dynamic per-condition background photos. Without this, the app
# falls back to static CSS gradients and works fine.
# 1. Create a free app at https://unsplash.com/developers (Register as a developer -> New Application)
# 2. Use the "Access Key" (not the Secret key) shown on your app's page.
# 3. Free tier is limited to 50 requests/hour; the app caches per weather
#    condition for 1 hour to stay well under that.
UNSPLASH_ACCESS_KEY=replace_with_your_unsplash_access_key
